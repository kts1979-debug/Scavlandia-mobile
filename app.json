{
  "expo": {
    "name": "Scavlandia",
    "slug": "scavlandia",
    "scheme": "scavlandia",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A5276"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.katesauls.scavlandia",
      "config": {
        "googleMapsApiKey": "AIzaSyD3WYNDd0gJLfGcAsvWIQFQdHt1Tv9rGYg"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Scavlandia needs your location to show you where hunt stops are and detect when you arrive.",
        "NSLocationAlwaysUsageDescription": "Scavlandia uses your location to track hunt progress.",
        "NSCameraUsageDescription": "Scavlandia needs camera access to take photos at hunt stops.",
        "NSPhotoLibraryUsageDescription": "Scavlandia saves hunt photos to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#1A5276"
      },
      "package": "com.katesauls.scavlandia",
      "versionCode": 3,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyD3WYNDd0gJLfGcAsvWIQFQdHt1Tv9rGYg"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO",
        "com.android.vending.BILLING"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Scavlandia to use your location to detect your city for hunt generation.",
          "locationWhenInUsePermission": "Allow Scavlandia to use your location to detect your city for hunt generation."
        }
      ],
      [
        "react-native-maps",
        {
          "googleMapsApiKey": "AIzaSyD3WYNDd0gJLfGcAsvWIQFQdHt1Tv9rGYg"
        }
      ],
      "expo-camera",
      "expo-media-library",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sharing"
    ],
    "extra": {
      "eas": {
        "projectId": "70eb3bd6-6d4e-4d8f-ac34-90f461de6744"
      }
    }
  }
}
